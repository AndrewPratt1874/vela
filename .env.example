SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-publishable-key

# Service role key (Supabase → Settings → API). Server-only; never expose.
# Required for sending ticket notification emails.
SUPABASE_SERVICE_KEY=your-service-role-key

# Outbound email (Mandrill SMTP). Used for ticket notifications.
MAIL_SMTP_HOST=smtp.mandrillapp.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=your-mandrill-username
MAIL_SMTP_PASS=your-mandrill-api-key
MAIL_FROM=noreply@codable.online
MAIL_FROM_NAME=Vela

# Public base URL, used for links in emails
APP_URL=http://localhost:3000
